# ==================== 平台配置 ====================

# IM 平台选择（当前支持: feishu）
IM_PLATFORM=feishu

# 多平台配置（逗号分隔，如: feishu,slack）
# 如果设置此项，系统将同时接入多个平台并广播消息
ENABLED_IM_PLATFORMS=feishu

# AI 助手选择（当前支持: claude_code, iflow）
AI_ASSISTANT_TYPE=claude_code

# ==================== 飞书配置 (IM_PLATFORM=feishu) ====================

# 飞书是否启用
FEISHU_ENABLED=true

FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# 消息发送配置
# 接收ID类型：open_id 或 user_id
FEISHU_MESSAGE_RECEIVE_ID_TYPE=open_id
# 域名：FEISHU_DOMAIN 或 FEISHU_US_DOMAIN
FEISHU_MESSAGE_DOMAIN=FEISHU_DOMAIN

# ==================== Tmux 会话配置 ====================

# tmux 会话名称
TMUX_SESSION_NAME=cc
# Session 最大未更新时间（分钟）
SESSION_MAX_AGE_MINUTES=30

# ==================== Claude Code 配置 (AI_ASSISTANT_TYPE=claude_code) ====================

# Claude Code 工作目录
CLAUDE_CODE_WORKSPACE_DIR=/path/to/ai/workspace
# Claude Code 日志文件
CLAUDE_CODE_LOG_FILE=/path/to/ai/logs
# Claude Code CLI 路径
CLAUDE_CODE_CLI_PATH=/path/to/your/ai/cli

# Claude Code Session ID（可选）
# 如果不设置，系统会自动查找或创建一个新的 session
# 可以从 ~/.claude/projects/<project-name>/ 目录中找到 session 文件名
# 设置后，所有命令将在同一 session 中执行，保持上下文
CLAUDE_CODE_SESSION_ID=

# ==================== iFlow 配置 (AI_ASSISTANT_TYPE=iflow) ====================

# iFlow CLI 路径
IFLOW_CLI=iflow
# iFlow 工作目录
IFLOW_DIR=/path/to/iflow/workspace

# ==================== Hook 配置 ====================

# AI Hook 脚本路径
AI_HOOK_SCRIPT=src/log_hook.py
# iFlow Hook 脚本路径
IFLOW_HOOK_SCRIPT=src/log_hook.py
# 是否启用 Hook
HOOK_ENABLED=true

# Hook 通知配置
# Stop hook 发送通知的目标用户 ID（open_id 或 user_id，与 FEISHU_MESSAGE_RECEIVE_ID_TYPE 对应）
FEISHU_HOOK_NOTIFICATION_USER_ID=

# 是否显示用户提问卡片（默认 false）
SHOW_USER_PROMPT_CARD=false
# 是否显示命令确认卡片（默认 false）
SHOW_COMMAND_CONFIRMATION_CARD=false

# ==================== 卡片消息配置 ====================

# 卡片最大长度（字符）
CARD_MAX_LENGTH=1500
# 使用安全的卡片格式化（处理特殊字符）
USE_SAFE_CARD_FORMATTING=true

# ==================== 文件消息配置 ====================

# 当内容超过 CARD_MAX_LENGTH 时，是否使用文件方式发送完整内容
USE_FILE_FOR_LONG_CONTENT=true
# 文件上传类型（stream, docx, pdf 等，默认 stream）
FILE_UPLOAD_TYPE=stream
# 上传文件存储目录（与图片下载共用）
UPLOAD_DIR=./uploads

# ==================== 截屏配置 ====================

# 截屏默认行数
TMUX_CAPTURE_LINES=200

# ==================== AI 自动重启配置 ====================

# 是否启用自动重启（AI 崩溃时自动恢复）
AI_AUTO_RESTART_ENABLED=true
# 最大重启尝试次数
AI_MAX_RESTART_ATTEMPTS=3
# 重启延迟时间（秒）
AI_RESTART_DELAY=5.0
# 崩溃检测间隔（秒，执行期间检查进程健康状态的频率）
AI_CRASH_DETECTION_INTERVAL=2.0

# ==================== 任务配置 ====================

# 任务超时时间（秒）
TASK_TIMEOUT=300
# 最大任务历史记录数
MAX_TASK_HISTORY=100

# ==================== 数据库配置 ====================

# 数据目录
DATA_DIR=./data
# 数据库路径
DB_PATH=./data/larkode.db

# ==================== 日志配置 ====================

# 日志目录
LOG_DIR=./logs
# 日志级别
LOG_LEVEL=INFO

# ==================== 权限模式 ====================

# 权限模式
PERMISSION_MODE=default

# ==================== Slack 配置 (IM_PLATFORM=slack) ====================

# Slack 是否启用
SLACK_ENABLED=false

# Slack Bot Token（格式: xoxb-...）
SLACK_BOT_TOKEN=your_bot_token
# Slack Signing Secret（用于验证请求签名）
SLACK_SIGNING_SECRET=your_signing_secret
# Slack App ID
SLACK_APP_ID=your_app_id

# ==================== 钉钉配置 (IM_PLATFORM=dingtalk) ====================

# 钉钉是否启用
DINGTALK_ENABLED=false

DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
